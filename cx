#!/usr/bin/env bash
# cx — Codex 多账号轮换器(cc-cli 家族成员, 与 cc 同装法; profile = 独立 CODEX_HOME 目录)
# 用法:
#   cx add <名>            # 新建 profile 并交互登录(订阅 OAuth 或贴 key)
#   cx list                # 列出 profiles 与登录态
#   cx exec <名> -- <codex参数...>   # 指定号执行
#   cx auto -- <codex参数...>        # ★自动轮换: 依次试, 烧到 limit 换下一个号★
# profile 目录: ~/.codex-profiles/<名>/ (各自 auth.json+config.toml, 互不影响)
set -u
PROF_ROOT="$HOME/.codex-profiles"
STATE="$PROF_ROOT/.last_good"          # 记住上次能用的号, auto 模式从它开始试
LIMIT_PAT='usage limit|rate.?limit|quota|429|insufficient_quota|limit reached|too many requests'
mkdir -p "$PROF_ROOT"

cmd=${1:-help}; shift || true
case "$cmd" in
  add)
    name=${1:?用法: cx.sh add <名>}
    home="$PROF_ROOT/$name"; mkdir -p "$home"
    # 默认官方线路(订阅); 要走中转就 add 完手改 $home/config.toml 加 model_providers 段
    [ -f "$home/config.toml" ] || printf 'model = "gpt-5.5"\n' > "$home/config.toml"
    echo "[cx] 开始登录 profile '$name'(订阅选 Sign in with ChatGPT):"
    CODEX_HOME="$home" codex login
    ;;
  list)
    for d in "$PROF_ROOT"/*/; do
      [ -d "$d" ] || continue
      n=$(basename "$d")
      [ -f "$d/auth.json" ] && s="已登录" || s="未登录"
      [ "$(cat "$STATE" 2>/dev/null)" = "$n" ] && s="$s ←上次可用"
      echo "$n  $s"
    done
    ;;
  exec)
    name=${1:?用法: cx.sh exec <名> -- <codex参数>}; shift
    [ "${1:-}" = "--" ] && shift
    CODEX_HOME="$PROF_ROOT/$name" codex "$@"
    ;;
  auto)
    [ "${1:-}" = "--" ] && shift
    # 轮换顺序: 上次可用的优先, 然后按目录序
    order=""
    last=$(cat "$STATE" 2>/dev/null || true)
    [ -n "$last" ] && [ -f "$PROF_ROOT/$last/auth.json" ] && order="$last"
    for d in "$PROF_ROOT"/*/; do
      n=$(basename "$d")
      [ -f "$d/auth.json" ] || continue
      [ "$n" = "$last" ] || order="$order $n"
    done
    [ -z "$order" ] && { echo "[cx] 没有已登录的 profile, 先 cx.sh add <名>" >&2; exit 2; }
    # 缓存 stdin(heredoc/管道): 否则第一个号消费掉后, 换号重试时 stdin 已空
    stdin_buf=$(mktemp)
    if [ ! -t 0 ]; then cat > "$stdin_buf"; fi
    for n in $order; do
      errf=$(mktemp)
      CODEX_HOME="$PROF_ROOT/$n" codex "$@" < "$stdin_buf" 2>"$errf"
      rc=$?
      if [ $rc -eq 0 ] && ! grep -qiE "$LIMIT_PAT" "$errf"; then
        echo "$n" > "$STATE"; cat "$errf" >&2; rm -f "$errf" "$stdin_buf"; exit 0
      fi
      if grep -qiE "$LIMIT_PAT" "$errf"; then
        echo "[cx] profile '$n' 触限, 换下一个号..." >&2; cat "$errf" >&2; rm -f "$errf"; continue
      fi
      # 非触限错误: 如实透出, 不再空烧其它号
      cat "$errf" >&2; rm -f "$errf"; exit $rc
    done
    echo "[cx] 全部 profile 都触限了" >&2; exit 3
    ;;
  *)
    grep '^#' "$0" | head -8 ;;
esac
